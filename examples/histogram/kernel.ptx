.version 7.0
.target sm_80
.address_size 64

.visible .entry histogram(
    .param .u64 histogram_param_0,
    .param .u64 histogram_param_1,
    .param .u32 histogram_param_2
) {
    .reg .pred  %p<2>;
    .reg .b32   %r<8>;
    .reg .b64   %rd<9>;

    ld.param.u64  %rd1, [histogram_param_0];
    ld.param.u64  %rd2, [histogram_param_1];
    ld.param.u32  %r2,  [histogram_param_2];
    mov.u32       %r3,  %ctaid.x;
    mov.u32       %r4,  %ntid.x;
    mov.u32       %r5,  %tid.x;
    mad.lo.s32    %r1,  %r3, %r4, %r5;
    setp.ge.s32   %p1,  %r1, %r2;
    @%p1 bra      $L__DONE;

    cvta.to.global.u64 %rd3, %rd1;
    mul.wide.s32  %rd4, %r1, 4;
    add.s64       %rd5, %rd3, %rd4;
    ld.global.u32 %r6,  [%rd5];

    cvta.to.global.u64 %rd6, %rd2;
    mul.wide.u32  %rd7, %r6, 4;
    add.u64       %rd8, %rd6, %rd7;
    atom.global.add.u32 %r7, [%rd8], 1;

$L__DONE:
    ret;
}
